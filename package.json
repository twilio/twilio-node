{
  "name": "twilio",
  "description": "A Twilio helper library",
  "version": "6.0.0",
  "type": "module",
  "author": "API Team <api@twilio.com>",
  "contributors": [
    {
      "name": "twilio-node contributors",
      "url": "https://github.com/twilio/twilio-node/graphs/contributors"
    }
  ],
  "keywords": [
    "twilio",
    "sms",
    "rest",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/twilio/twilio-node.git"
  },
  "dependencies": {
    "jsonwebtoken": "9.0.3",
    "xmlbuilder": "15.1.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.3.3",
    "eslint": "10.0.2",
    "mock-fs": "5.5.0",
    "node-mocks-http": "1.17.2",
    "prettier": "3.8.1",
    "typedoc": "0.28.17",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:typescript",
    "test:unit": "vitest run --coverage",
    "test:typescript": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublish": "npm run build",
    "build": "tsc",
    "ci": "npm run test && npm run nsp && npm run prettier-check",
    "nsp": "npm audit --production",
    "prettier": "prettier --write .",
    "prettier-check": "prettier --check .",
    "typedoc": "typedoc --entryPointStrategy expand src --out docs --logLevel Error"
  },
  "sideEffects": false,
  "files": [
    "lib"
  ],
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./webhooks": {
      "types": "./lib/webhooks/webhooks.d.ts",
      "import": "./lib/webhooks/webhooks.js"
    },
    "./jwt": {
      "types": "./lib/jwt/AccessToken.d.ts",
      "import": "./lib/jwt/AccessToken.js"
    },
    "./twiml": {
      "types": "./lib/twiml/VoiceResponse.d.ts",
      "import": "./lib/twiml/VoiceResponse.js"
    },
    "./twiml/VoiceResponse": {
      "types": "./lib/twiml/VoiceResponse.d.ts",
      "import": "./lib/twiml/VoiceResponse.js"
    },
    "./twiml/MessagingResponse": {
      "types": "./lib/twiml/MessagingResponse.d.ts",
      "import": "./lib/twiml/MessagingResponse.js"
    },
    "./twiml/FaxResponse": {
      "types": "./lib/twiml/FaxResponse.d.ts",
      "import": "./lib/twiml/FaxResponse.js"
    }
  },
  "engines": {
    "node": ">=18.0"
  },
  "license": "MIT"
}
